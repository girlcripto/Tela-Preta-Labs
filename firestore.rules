rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidStepProgress(data) {
      return data.keys().hasAll(['userId', 'stepId', 'isCompleted', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.stepId is int &&
             data.isCompleted is bool &&
             data.updatedAt is timestamp &&
             (!data.keys().contains('completedSubSteps') || data.completedSubSteps is list);
    }

    function isValidQuizResult(data) {
      return data.keys().hasAll(['userId', 'stepId', 'score', 'totalQuestions', 'completedAt']) &&
             data.userId == request.auth.uid &&
             data.stepId is int &&
             data.score is int &&
             data.totalQuestions is int &&
             data.completedAt is timestamp;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
      
      match /progress/{stepId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidStepProgress(incoming());
        allow update: if isOwner(userId) && isValidStepProgress(incoming()) &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['completedSubSteps', 'isCompleted', 'updatedAt']);
      }

      match /quizzes/{quizId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidQuizResult(incoming());
      }
    }

    match /certificates/{certificateId} {
      allow read: if true; // Publicly verifiable
      allow create: if isSignedIn(); // User creates their own certificate upon completion (logic should be stricter but for now OK)
    }
  }
}
